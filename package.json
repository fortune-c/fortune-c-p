{
  "name": "fortune-c-p",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./styles/input.css -o ./styles/output.css --watch",
    "build:ts": "tsc --watch",
    "build": "tailwindcss -i ./styles/input.css -o ./styles/output.css && tsc",
    "dev": "npm run build:css & npm run build:ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fontsource/bungee": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8"
  }
}
