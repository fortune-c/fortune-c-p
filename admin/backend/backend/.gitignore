## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is for a .NET project.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bbin/
obj/
external/
node_modules/

# Visual Studio 2015/2017/2019/2022 cache and settings
.vs/
# Uncomment if you want to ignore the whole .vs folder
# .vs/

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image build caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on slower drives
$RECYCLE.BIN/

# Others
publish/
*.bundleconfig.json
*.[Cc]ompiled.css

# Specialized databases
*.mdf
*.ldf
*.ndf

# Local History for Visual Studio
.localhistory/

# ASP.NET Core
project.lock.json
project.fragment.lock.json
artifacts/
**/App_Data/

# Secret manager
secrets.json

# Server-side user settings
appsettings.Development.json
appsettings.json

# MongoDB local data (if running locally in this folder)
# data/db/

# MacOS files
.DS_Store
